[Unit]
Description=DiTing Tetragon Collector
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=diting
Group=diting
WorkingDirectory=/opt/diting/backend
ExecStart=/opt/diting/bin/audit-server collector --config /etc/diting/config.yaml
Restart=always
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
