[Unit]
Description=DiTing API Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=diting
Group=diting
WorkingDirectory=/opt/diting/backend
ExecStart=/opt/diting/bin/audit-server api --config /etc/diting/config.yaml
Restart=always
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
